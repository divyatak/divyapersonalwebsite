---
import { ViewTransitions } from 'astro:transitions'

interface Props {
  title?: string
  description?: string
}

const { title = 'Divya — Artist Portfolio', description = 'Portfolio of Divya — artist, maker, collaborator. A space for work and the people I create with.' } = Astro.props

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const pathname = Astro.url.pathname

const navItems = [
  { label: 'hello', href: `${base}/` },
  { label: 'works', href: `${base}/works/` },
  { label: 'friends', href: `${base}/friends/` },
  { label: 'about', href: `${base}/about/` },
]

function isActive(href: string) {
  if (href === `${base}/`) return pathname === `${base}/` || pathname === base || pathname === '/'
  return pathname.startsWith(href)
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}/favicon-32.png`} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;300;400;600;700;800&display=swap" /></noscript>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${base}/og-image.png`} />
    <ViewTransitions />
  </head>
  <body>
    <div class="layout">
      <a href="#main-content" class="skip-link">Skip to main content</a>
      <nav class="sidebar" transition:persist aria-label="Main navigation">
        <span class="sidebar-name">divya tak</span>
        <div class="sidebar-links">
          {navItems.map(item => (
            <a
              href={item.href}
              class:list={['nav-item', { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        <div class="sidebar-socials">
          <a href="https://www.instagram.com/divyatakart/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/divya-tak-56019522/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://divyatak.substack.com" target="_blank" rel="noopener noreferrer" aria-label="Substack">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24l9.54-5.347L20.539 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
          </a>
        </div>
      </nav>
      <main class="content" id="main-content">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  function initAnimations() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // Sidebar first-visit entrance
    const sidebar = document.querySelector('.sidebar')
    if (sidebar) {
      if (!sessionStorage.getItem('sidebar-entered')) {
        sidebar.classList.add('sidebar--entering')
        // Trigger reflow, then start animation
        requestAnimationFrame(() => {
          sidebar.classList.remove('sidebar--entering')
          sidebar.classList.add('sidebar--entered')
          sessionStorage.setItem('sidebar-entered', '1')
        })
      }
    }

    // Scroll-triggered animations
    if (prefersReduced) {
      document.querySelectorAll('.animate-in').forEach(el => el.classList.add('visible'))
      return
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return

        const el = entry.target

        // If this is a stagger parent, reveal children with stagger delays
        if (el.dataset.staggerChildren !== undefined) {
          const children = el.querySelectorAll('.animate-in:not(.visible)')
          const staggerMs = parseInt(el.dataset.staggerMs || '80')
          const cap = 6
          children.forEach((child, i) => {
            const delay = Math.min(i, cap - 1) * staggerMs
            child.style.setProperty('--enter-delay', `${delay}ms`)
            child.classList.add('visible')
          })
          if (el.classList.contains('animate-in')) {
            el.classList.add('visible')
          }
        } else {
          el.classList.add('visible')
        }

        observer.unobserve(el)
      })
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' })

    document.querySelectorAll('.animate-in').forEach(el => {
      // Don't observe children that will be stagger-revealed by their parent
      if (el.closest('[data-stagger-children]') && !el.hasAttribute('data-stagger-children')) return
      observer.observe(el)
    })

    // Also observe stagger parents that aren't .animate-in themselves
    document.querySelectorAll('[data-stagger-children]:not(.animate-in)').forEach(el => {
      observer.observe(el)
    })
  }

  // Update sidebar active state on navigation
  function updateSidebarActive() {
    const path = window.location.pathname
    document.querySelectorAll('.nav-item').forEach(item => {
      const href = item.getAttribute('href') || ''
      const isHome = href.endsWith('/') && !href.includes('/works') && !href.includes('/friends') && !href.includes('/about')
      const isActive = isHome
        ? (path === href || path === href.slice(0, -1) || path === '/')
        : path.startsWith(href)
      item.classList.toggle('active', isActive)
      if (isActive) {
        item.setAttribute('aria-current', 'page')
      } else {
        item.removeAttribute('aria-current')
      }
    })
  }

  // Run on initial load
  initAnimations()

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', () => {
    updateSidebarActive()
    initAnimations()
  })
</script>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/app.css';
</style>
