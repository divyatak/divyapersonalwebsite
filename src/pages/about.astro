---
import Layout from '../layouts/Layout.astro'
import aboutData from '../data/generated-about.json'

const { bio, email, photo, talks, workshops, press } = aboutData
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<Layout title="About — Divya" description="Divya Tak is a multidisciplinary creative whose work spans film, games, comics, interactive systems, and generative media.">
  <section aria-label="About" class="about-intro">
    <h1 class="sr-only">About</h1>
    {photo ? (
      <img src={`${base}${photo}`} alt="Divya Tak" class="about-photo animate-in" style="--enter-scale: 0.97" loading="lazy" />
    ) : (
      <div class="about-photo-placeholder"></div>
    )}
    <div class="about-intro-text animate-in" style="--enter-delay: 0.2s">
      <div class="artist-statement">
        <p>Divya Tak is a multidisciplinary creative whose work spans film, games, comics, interactive systems, and generative media, contributing to award-winning projects while pursuing a sustained inquiry into wonder, curiosity, and belonging. Trained in physics and shaped by over a decade of working across creative industries, she approaches storytelling as a study of perception itself, how we see, what we overlook, and how meaning forms between systems and humans.</p>
        <p>Her visual poetry collaboration with poet Kahran Singh was exhibited in Boulder, Colorado in January 2025. She worked as Creative Producer on the film Jugnuma, which won Best Film at Leeds 2025. Her narrative game The Titli Effect placed second at The Jennifer Ann Group's Connectedness Game Jam. She has created cover illustrations for scientific journals between 2018 and 2024, and her original comic Common was published in the INKLAB Anthology in 2021. She completed the Pollinator Creative Program in November 2025 and the BHX Creators Residency in March 2025.</p>
      </div>
    </div>
  </section>

  {email && (
    <section aria-label="Contact" class="about-section animate-in">
      <h3 class="about-subheading">for queries & commissions</h3>
      <p class="contact-text">
        Reach out at <a href={`mailto:${email}`} class="contact-email">{email}</a>
      </p>
    </section>
  )}

  <section aria-label="Talks and workshops" class="about-section">
    <div class="logo-strip" data-stagger-children data-stagger-ms="60">
      <img class="animate-in" src={`${base}/logos/google.webp`} alt="Google India" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/ngma.gif`} alt="NGMA Bangalore" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/goethe-institut.png`} alt="Goethe Institut" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/iimb.png`} alt="IIM Bangalore" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/layers.png`} alt="Friends of Figma / Layers Portugal" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/hasgeek.svg`} alt="HasGeek" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/uxdx.webp`} alt="UXDX" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/slush.webp`} alt="Slush'd" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/gafx.webp`} alt="GAFX Bangalore" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/bangalore-international-centre.png`} alt="Bangalore International Centre" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/agifest.png`} alt="AGI Fest" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/litschool.png`} alt="LIT School" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/christ-university.webp`} alt="Christ University" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/startout.svg`} alt="StartOut" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/ai-enthusiasts-circle.webp`} alt="AI Enthusiasts Circle" loading="lazy" />
      <img class="animate-in" src={`${base}/logos/ajaibghar.webp`} alt="Ajaibghar / Lab59" loading="lazy" />
    </div>
    <div class="two-col animate-in">
      <div>
        <h3 class="about-subheading">talks & panels</h3>
        <ul class="talk-list">
          {talks.map((t) => (
            <li class="talk-item">
              <span class="talk-venue">{t.venue}{t.year ? ` '${String(t.year).slice(2)}` : ''}</span>
              {t.url ? (
                <a href={t.url} target="_blank" rel="noopener noreferrer" class="talk-name">{t.title}</a>
              ) : (
                <span class="talk-name">{t.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="about-subheading">workshops</h3>
        <ul class="talk-list">
          {workshops.map((t) => (
            <li class="talk-item">
              <span class="talk-venue">{t.venue}{t.year ? ` '${String(t.year).slice(2)}` : ''}</span>
              {t.url ? (
                <a href={t.url} target="_blank" rel="noopener noreferrer" class="talk-name">{t.title}</a>
              ) : (
                <span class="talk-name">{t.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {press.length > 0 && (
    <section aria-label="Publications" class="about-section animate-in">
      <h3 class="about-subheading">publications & features</h3>
      <ul class="about-list">
        {press.map((p) => (
          <li>
            {p.url ? (
              <a href={p.url} target="_blank" rel="noopener noreferrer">{p.title}</a>
            ) : (
              <span>{p.title}</span>
            )}
            {p.outlet && ` — ${p.outlet}`}{p.year ? `, ${p.year}` : ''}
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
