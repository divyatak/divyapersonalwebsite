---
import Layout from '../layouts/Layout.astro'
import aboutData from '../data/generated-about.json'

const { bio, email, photo, talks, workshops, press } = aboutData

// Convert plain text bio to HTML, linking "Joyus Studio"
function linkifyBio(text) {
  return text.replace(
    /Joyus Studio/g,
    '<a href="https://joyus.studio/" target="_blank" rel="noopener noreferrer">Joyus Studio</a>'
  )
}
---

<Layout title="About — Divya" description={bio[0] || "Divya Tak is a multi-disciplinary designer and creative."}>
  <section aria-label="About" class="about-intro">
    <h1 class="sr-only">About</h1>
    {photo ? (
      <img src={photo} alt="Divya Tak" class="about-photo" loading="lazy" />
    ) : (
      <div class="about-photo-placeholder"></div>
    )}
    <div class="about-intro-text">
      <div class="artist-statement">
        {bio.map((paragraph) => (
          <p set:html={linkifyBio(paragraph)} />
        ))}
      </div>
      {email && <a href={`mailto:${email}`} class="about-email">{email}</a>}
    </div>
  </section>

  <section aria-label="Talks and workshops" class="about-section">
    <div class="logo-strip">
      <img src="/logos/google.webp" alt="Google India" loading="lazy" />
      <img src="/logos/goethe-institut.png" alt="Goethe Institut" loading="lazy" />
      <img src="/logos/iimb.png" alt="IIM Bangalore" loading="lazy" />
      <img src="/logos/gafx.webp" alt="GAFX Bangalore" loading="lazy" />
      <img src="/logos/slush.webp" alt="Slush'd" loading="lazy" />
      <img src="/logos/uxdx.webp" alt="UXDX" loading="lazy" />
      <img src="/logos/christ-university.webp" alt="Christ University" loading="lazy" />
      <img src="/logos/bangalore-international-centre.png" alt="Bangalore International Centre" loading="lazy" />
      <img src="/logos/agifest.png" alt="AGI Fest" loading="lazy" />
      <img src="/logos/startout.svg" alt="StartOut" loading="lazy" />
      <img src="/logos/ai-enthusiasts-circle.webp" alt="AI Enthusiasts Circle" loading="lazy" />
      <img src="/logos/ajaibghar.webp" alt="AjaibGhar" loading="lazy" />
    </div>
    <div class="two-col">
      <div>
        <h3 class="about-subheading">talks & panels</h3>
        <ul class="talk-list">
          {talks.map((t) => (
            <li class="talk-item">
              <span class="talk-venue">{t.venue}{t.year ? ` '${String(t.year).slice(2)}` : ''}</span>
              {t.url ? (
                <a href={t.url} target="_blank" rel="noopener noreferrer" class="talk-name">{t.title}</a>
              ) : (
                <span class="talk-name">{t.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="about-subheading">workshops</h3>
        <ul class="talk-list">
          {workshops.map((t) => (
            <li class="talk-item">
              <span class="talk-venue">{t.venue}{t.year ? ` '${String(t.year).slice(2)}` : ''}</span>
              {t.url ? (
                <a href={t.url} target="_blank" rel="noopener noreferrer" class="talk-name">{t.title}</a>
              ) : (
                <span class="talk-name">{t.title}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {press.length > 0 && (
    <section aria-label="Publications" class="about-section">
      <h3 class="about-subheading">publications & features</h3>
      <ul class="about-list">
        {press.map((p) => (
          <li>
            {p.url ? (
              <a href={p.url} target="_blank" rel="noopener noreferrer">{p.title}</a>
            ) : (
              <span>{p.title}</span>
            )}
            {p.outlet && ` — ${p.outlet}`}{p.year ? `, ${p.year}` : ''}
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
