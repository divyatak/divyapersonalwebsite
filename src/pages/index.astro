---
import Layout from '../layouts/Layout.astro'
import HeroPixelDisplace from '../components/HeroPixelDisplace.astro'
import works from '../data/generated-projects.json'

// Collect high-res interior images from (un)seen projects only
const MIN_DIM = 800
const heroImages = works
  .flatMap(y => y.projects)
  .filter(p => p.title.toLowerCase().includes('unseen') || p.title.includes('(un)seen'))
  .flatMap(p => p.media
    .filter(m => m.type === 'image' && m.width && m.height && Math.min(m.width, m.height) >= MIN_DIM)
    .map(m => ({ src: m.src }))
  )
---

<Layout>
  <section aria-label="Introduction" class="home-section">
    <h1 class="sr-only">Divya — Artist Portfolio</h1>
    <div class="home-hero">
      <HeroPixelDisplace images={heroImages} />
    </div>
    <div class="home-text animate-in" style="--enter-delay: 0.4s">
      <p class="divya-intro">
        Hi! Hello! I'm Divya.<br />
        I am a cross domain creative human. I love making many things with many people.
      </p>
      <p class="divya-intro-details">
        I run a storytelling studio called <a href="https://joyus.studio" target="_blank" rel="noopener noreferrer">Joyus</a> with my friend <a href="https://kahransingh.com" target="_blank" rel="noopener noreferrer">Kahran</a>.<br />
        I lead product design for Klydo.<br />
        I make games with my sister <a href="https://charutak.xyz" target="_blank" rel="noopener noreferrer">Charu</a>.<br />
        I often collaborate with <a href="https://varuns.work" target="_blank" rel="noopener noreferrer">Varun Ramanna</a> on VFX projects.
      </p>
      <p class="divya-intro divya-intro-coda">
        You are at the home of some of my creations.
      </p>
    </div>
  </section>
</Layout>

<script>
  // Redirect old hash-based URLs to proper routes
  const hash = window.location.hash.replace('#', '')
  if (hash) {
    const parts = hash.split('/')
    const section = parts[0]
    if (section === 'works' && parts[1]) {
      window.location.replace('/works/' + parts[1] + '/')
    } else if (section === 'works') {
      window.location.replace('/works/')
    } else if (section === 'friends') {
      window.location.replace('/friends/')
    } else if (section === 'about') {
      window.location.replace('/about/')
    }
  }
</script>
