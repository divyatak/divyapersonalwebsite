---
import Layout from '../layouts/Layout.astro'
import HeroPixelDisplace from '../components/HeroPixelDisplace.astro'
import works from '../data/generated-projects.json'

// Collect high-res interior images from (un)seen projects only
const MIN_DIM = 800
const heroImages = works
  .flatMap(y => y.projects)
  .filter(p => p.title.toLowerCase().includes('unseen') || p.title.includes('(un)seen'))
  .flatMap(p => p.media
    .filter(m => m.type === 'image' && m.width && m.height && Math.min(m.width, m.height) >= MIN_DIM)
    .map(m => ({ src: m.src }))
  )
---

<Layout>
  <section aria-label="Introduction" class="home-section">
    <h1 class="sr-only">Divya — Artist Portfolio</h1>
    <div class="home-hero">
      <HeroPixelDisplace images={heroImages} />
    </div>
    <div class="home-text animate-in" style="--enter-delay: 0.8s">
      <p class="divya-intro">
        Hello, I'm Divya — artist, maker, collaborator.
        This is a space for my work and the people I create with.
      </p>
    </div>
  </section>
</Layout>

<script>
  // Redirect old hash-based URLs to proper routes
  const hash = window.location.hash.replace('#', '')
  if (hash) {
    const parts = hash.split('/')
    const section = parts[0]
    if (section === 'works' && parts[1]) {
      window.location.replace('/works/' + parts[1] + '/')
    } else if (section === 'works') {
      window.location.replace('/works/')
    } else if (section === 'friends') {
      window.location.replace('/friends/')
    } else if (section === 'about') {
      window.location.replace('/about/')
    }
  }
</script>
