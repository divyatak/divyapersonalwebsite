---
const { images } = Astro.props
---

<div class="hero-container hero-pixel" id="hero-pixel">
  <canvas id="pixel-canvas"></canvas>
  {images.map((img) => (
    <img data-src={img.src} class="pixel-source" alt="" />
  ))}
</div>

<style>
  .hero-pixel {
    position: relative;
    cursor: default;
    overflow: visible;
    pointer-events: auto;
  }

  #pixel-canvas {
    position: absolute;
    top: -40px;
    left: -40px;
    display: block;
    pointer-events: none;
  }

  .pixel-source {
    display: none;
  }
</style>

<script>
  function initPixelDisplace() {
    const container = document.getElementById('hero-pixel')
    if (!container) return

    const rect = container.getBoundingClientRect()
    if (rect.width < 10 || rect.height < 10) return
    if (container.dataset.initialized === 'true') return
    container.dataset.initialized = 'true'

    const canvas = document.getElementById('pixel-canvas') as HTMLCanvasElement
    if (!canvas) return

    const ctx = canvas.getContext('2d')
    if (!ctx) return

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // Collect all source URLs, shuffle them
    const sources = Array.from(container.querySelectorAll('.pixel-source')) as HTMLImageElement[]
    if (sources.length === 0) return
    const srcUrls = sources.map(s => s.dataset.src || '').filter(Boolean)
    for (let i = srcUrls.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [srcUrls[i], srcUrls[j]] = [srcUrls[j], srcUrls[i]]
    }

    const dpr = window.devicePixelRatio || 1
    const PAD = 40
    const w = rect.width
    const h = rect.height
    const cw = w + PAD * 2
    const ch = h + PAD * 2

    canvas.width = cw * dpr
    canvas.height = ch * dpr
    canvas.style.width = cw + 'px'
    canvas.style.height = ch + 'px'
    ctx.scale(dpr, dpr)

    const TILE_SIZE = 14
    const cols = Math.ceil(w / TILE_SIZE)
    const rows = Math.ceil(h / TILE_SIZE)
    const containerAspect = w / h

    // Current image state (mutable for cycling)
    let currentImg: HTMLImageElement | null = null
    let srcX = 0, srcY = 0, srcW = 0, srcH = 0

    function computeCrop(img: HTMLImageElement) {
      const imgAspect = img.naturalWidth / img.naturalHeight
      if (imgAspect > containerAspect) {
        srcH = img.naturalHeight
        srcW = srcH * containerAspect
        srcX = (img.naturalWidth - srcW) / 2
        srcY = 0
      } else {
        srcW = img.naturalWidth
        srcH = srcW / containerAspect
        srcX = 0
        srcY = (img.naturalHeight - srcH) / 2
      }
    }

    // Per-tile state
    const tiles: { cx: number; cy: number; offsetX: number; offsetY: number; targetX: number; targetY: number; angleJitter: number; strengthMult: number }[] = []
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        tiles.push({
          cx: c * TILE_SIZE + TILE_SIZE / 2,
          cy: r * TILE_SIZE + TILE_SIZE / 2,
          offsetX: 0,
          offsetY: 0,
          targetX: 0,
          targetY: 0,
          angleJitter: (Math.random() - 0.5) * 1.2,
          strengthMult: 0.5 + Math.random() * 1.0,
        })
      }
    }

    const STRENGTH = 40
    const RADIUS = 220

    let mouseX = -9999
    let mouseY = -9999
    let mouseInside = false
    let animating = false

    // Crossfade state
    let fadeAlpha = 1 // 1 = fully visible, fades to 0 then back to 1 on swap
    let fading = false

    function computeTargets() {
      for (const tile of tiles) {
        if (!mouseInside) {
          tile.targetX = 0
          tile.targetY = 0
          continue
        }
        const dx = tile.cx - mouseX
        const dy = tile.cy - mouseY
        const dist = Math.sqrt(dx * dx + dy * dy)

        if (dist > RADIUS || dist < 0.1) {
          tile.targetX = 0
          tile.targetY = 0
          continue
        }

        const force = STRENGTH * (1 - dist / RADIUS) * tile.strengthMult
        const angle = Math.atan2(dy, dx) + tile.angleJitter
        tile.targetX = Math.cos(angle) * force
        tile.targetY = Math.sin(angle) * force
      }
    }

    function draw() {
      ctx.clearRect(0, 0, cw, ch)
      if (!currentImg) { animating = false; return }

      let stillMoving = false

      // Apply fade alpha
      const prevAlpha = ctx.globalAlpha
      ctx.globalAlpha = fadeAlpha

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const tile = tiles[r * cols + c]

          const dxL = tile.targetX - tile.offsetX
          const dyL = tile.targetY - tile.offsetY
          if (Math.abs(dxL) > 0.05 || Math.abs(dyL) > 0.05) {
            tile.offsetX += dxL * 0.1
            tile.offsetY += dyL * 0.1
            stillMoving = true
          } else {
            tile.offsetX = tile.targetX
            tile.offsetY = tile.targetY
          }

          const tileSrcX = srcX + (c * TILE_SIZE / w) * srcW
          const tileSrcY = srcY + (r * TILE_SIZE / h) * srcH
          const tileSrcW = (TILE_SIZE / w) * srcW
          const tileSrcH = (TILE_SIZE / h) * srcH

          const destX = PAD + c * TILE_SIZE + tile.offsetX
          const destY = PAD + r * TILE_SIZE + tile.offsetY

          ctx.drawImage(
            currentImg,
            tileSrcX, tileSrcY, tileSrcW, tileSrcH,
            destX, destY, TILE_SIZE, TILE_SIZE
          )
        }
      }

      ctx.globalAlpha = prevAlpha

      if (fading || stillMoving) {
        requestAnimationFrame(draw)
      } else {
        animating = false
      }
    }

    function startAnimation() {
      if (!animating) {
        animating = true
        requestAnimationFrame(draw)
      }
    }

    // --- Image cycling ---
    let imgIndex = 0
    let nextImg: HTMLImageElement | null = null

    function preloadNext() {
      const nextIndex = (imgIndex + 1) % srcUrls.length
      const img = new Image()
      img.src = srcUrls[nextIndex]
      img.onload = () => { nextImg = img }
    }

    function swapImage() {
      if (!nextImg || srcUrls.length < 2) return

      // Fade out
      fading = true
      startAnimation()

      function fadeOut() {
        fadeAlpha -= 0.03
        if (fadeAlpha <= 0) {
          fadeAlpha = 0
          // Swap
          imgIndex = (imgIndex + 1) % srcUrls.length
          currentImg = nextImg
          computeCrop(currentImg!)
          nextImg = null
          preloadNext()
          // Fade in
          fadeIn()
          return
        }
        requestAnimationFrame(fadeOut)
      }

      function fadeIn() {
        fadeAlpha += 0.03
        if (fadeAlpha >= 1) {
          fadeAlpha = 1
          fading = false
          if (!animating) startAnimation() // one final draw at full alpha
          return
        }
        requestAnimationFrame(fadeIn)
      }

      fadeOut()
    }

    // Load first image
    const firstImg = new Image()
    firstImg.src = srcUrls[0]
    firstImg.onload = () => {
      currentImg = firstImg
      computeCrop(currentImg)

      // Initial static draw
      ctx.drawImage(currentImg, srcX, srcY, srcW, srcH, PAD, PAD, w, h)

      // Start preloading next
      if (srcUrls.length > 1) preloadNext()

      // Cycle every 5 seconds
      if (!reducedMotion && srcUrls.length > 1) {
        setInterval(swapImage, 7000)
      }

      if (reducedMotion) return

      container.addEventListener('mousemove', (e) => {
        const r = container.getBoundingClientRect()
        mouseX = e.clientX - r.left
        mouseY = e.clientY - r.top
        mouseInside = true
        computeTargets()
        startAnimation()
      })

      container.addEventListener('touchmove', (e) => {
        const touch = e.touches[0]
        const r = container.getBoundingClientRect()
        mouseX = touch.clientX - r.left
        mouseY = touch.clientY - r.top
        mouseInside = true
        computeTargets()
        startAnimation()
      }, { passive: true })

      container.addEventListener('mouseleave', () => {
        mouseInside = false
        computeTargets()
        startAnimation()
      })

      container.addEventListener('touchend', () => {
        mouseInside = false
        computeTargets()
        startAnimation()
      })
    }
  }

  document.addEventListener('hero-pixel-activate', initPixelDisplace)
  initPixelDisplace()
  document.addEventListener('astro:after-swap', initPixelDisplace)
</script>
