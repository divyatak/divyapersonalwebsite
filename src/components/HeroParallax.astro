---
const { projects } = Astro.props
---

<div class="hero-container hero-parallax" id="hero-parallax">
  {projects.map((p) => (
    <a
      href={`/works/${p.slug}/`}
      class:list={['parallax-card', 'parallax-card--candidate', { 'parallax-card--portrait': p.coverOrientation === 'portrait', 'parallax-card--landscape': p.coverOrientation !== 'portrait' }]}
      data-cover={p.cover}
      data-orientation={p.coverOrientation || 'landscape'}
    >
      <img data-src={p.cover} alt={p.title} decoding="async" />
      <span class="parallax-card-title">{p.title}</span>
    </a>
  ))}
</div>

<style>
  .hero-parallax {
    position: relative;
  }

  /* All cards hidden until JS picks them */
  .parallax-card--candidate {
    display: none;
  }

  .parallax-card {
    position: absolute;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    transition: box-shadow 0.2s;
    will-change: transform;
    text-decoration: none;
    color: inherit;
  }

  .parallax-card--portrait {
    width: 22%;
    aspect-ratio: 3 / 4;
  }

  .parallax-card--landscape {
    width: 28%;
    aspect-ratio: 3 / 2;
  }

  /* Entrance: hidden state */
  .parallax-card--entering {
    opacity: 0;
    transform: rotate(var(--rotation)) scale(0.96);
  }

  /* Entrance: animating in */
  .parallax-card--entered {
    opacity: 1;
    transform: rotate(var(--rotation)) scale(1);
    transition:
      opacity var(--duration-slow) var(--ease-settle),
      transform var(--duration-slow) var(--ease-settle),
      box-shadow 0.2s;
  }

  .parallax-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
    z-index: 20 !important;
  }

  .parallax-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }

  .parallax-card-title {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-align: center;
    color: #fff;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .parallax-card:hover .parallax-card-title {
    opacity: 1;
  }

  @media (hover: none) {
    .parallax-card-title {
      opacity: 0;
    }
  }
</style>

<script>
  function initParallax() {
    const container = document.getElementById('hero-parallax')
    if (!container || container.dataset.initialized) return
    container.dataset.initialized = 'true'

    const layouts = [
      { left: 2,  top: 0,  depth: 0.3, rotation: -2.5 },
      { left: 38, top: 2,  depth: 0.7, rotation: 3 },
      { left: 68, top: 4,  depth: 0.4, rotation: -1.5 },
      { left: 10, top: 20, depth: 0.6, rotation: 2 },
      { left: 42, top: 18, depth: 0.5, rotation: -3.5 },
      { left: 65, top: 22, depth: 0.8, rotation: 1.5 },
      { left: 0,  top: 40, depth: 0.4, rotation: -2 },
      { left: 35, top: 38, depth: 0.6, rotation: 4 },
      { left: 64, top: 42, depth: 0.3, rotation: -1 },
      { left: 5,  top: 60, depth: 0.7, rotation: 3.5 },
      { left: 38, top: 58, depth: 0.5, rotation: -2.5 },
      { left: 66, top: 62, depth: 0.4, rotation: 2 },
    ]

    // Gather all candidate cards, shuffle, pick up to 12
    const allCards = Array.from(container.querySelectorAll('.parallax-card--candidate')) as HTMLElement[]
    for (let i = allCards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [allCards[i], allCards[j]] = [allCards[j], allCards[i]]
    }

    const isMobile = window.innerWidth <= 768
    const count = isMobile ? Math.min(8, allCards.length) : Math.min(12, allCards.length)
    const selected = allCards.slice(0, count)

    // Per-card lerp state
    const cardState = new Map<HTMLElement, {
      currentX: number
      currentY: number
      depth: number
      rotation: number
      ready: boolean
    }>()

    // Position cards, keep hidden for entrance
    selected.forEach((card, i) => {
      const layout = layouts[i]
      card.style.left = `${layout.left}%`
      card.style.top = `${layout.top}%`
      card.style.zIndex = String(Math.floor(layout.depth * 10))
      card.style.setProperty('--depth', String(layout.depth))
      card.style.setProperty('--rotation', `${layout.rotation}deg`)

      const img = card.querySelector('img') as HTMLImageElement
      if (img && img.dataset.src) {
        img.src = img.dataset.src
        img.loading = i < 6 ? 'eager' : 'lazy'
      }

      // Show card but keep visually hidden for entrance animation
      card.classList.add('parallax-card--entering')
      card.classList.remove('parallax-card--candidate')

      cardState.set(card, {
        currentX: 0,
        currentY: 0,
        depth: layout.depth,
        rotation: layout.rotation,
        ready: false,
      })
    })

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    // Center-outward entrance stagger
    requestAnimationFrame(() => {
      const rect = container.getBoundingClientRect()
      const cx = rect.width / 2
      const cy = rect.height / 2

      const sorted = [...selected].sort((a, b) => {
        const ar = a.getBoundingClientRect()
        const br = b.getBoundingClientRect()
        const ad = Math.hypot(
          ar.left + ar.width / 2 - rect.left - cx,
          ar.top + ar.height / 2 - rect.top - cy
        )
        const bd = Math.hypot(
          br.left + br.width / 2 - rect.left - cx,
          br.top + br.height / 2 - rect.top - cy
        )
        return ad - bd
      })

      sorted.forEach((card, i) => {
        const delay = reducedMotion ? 0 : i * 80 + 100

        setTimeout(() => {
          card.classList.remove('parallax-card--entering')
          card.classList.add('parallax-card--entered')

          if (reducedMotion) {
            // Skip transition, mark ready immediately
            const state = cardState.get(card)
            if (state) state.ready = true
            return
          }

          // After entrance transition ends, hand off to lerp
          function onEntranceDone(e: TransitionEvent) {
            if (e.propertyName !== 'opacity') return
            card.removeEventListener('transitionend', onEntranceDone)
            card.classList.remove('parallax-card--entered')
            // Set inline transform so there's no jump when class is removed
            const state = cardState.get(card)
            if (state) {
              card.style.transform = `rotate(${state.rotation}deg) translate(0px, 0px)`
              state.ready = true
            }
          }

          card.addEventListener('transitionend', onEntranceDone)

          // Fallback in case transitionend doesn't fire
          setTimeout(() => {
            const state = cardState.get(card)
            if (state && !state.ready) {
              card.removeEventListener('transitionend', onEntranceDone)
              card.classList.remove('parallax-card--entered')
              card.style.transform = `rotate(${state.rotation}deg) translate(0px, 0px)`
              state.ready = true
            }
          }, 1200)
        }, delay)
      })
    })

    // Lerp-based parallax
    if (reducedMotion) return

    const MAX_SHIFT = Math.min(40, container.offsetWidth * 0.06)
    let targetDx = 0
    let targetDy = 0
    let animating = false

    function tick() {
      let stillMoving = false

      selected.forEach(card => {
        const state = cardState.get(card)
        if (!state || !state.ready) return

        const tx = targetDx * state.depth * MAX_SHIFT
        const ty = targetDy * state.depth * MAX_SHIFT
        const dx = tx - state.currentX
        const dy = ty - state.currentY

        if (Math.abs(dx) > 0.1 || Math.abs(dy) > 0.1) {
          state.currentX += dx * 0.08
          state.currentY += dy * 0.08
          stillMoving = true
        } else {
          state.currentX = tx
          state.currentY = ty
        }

        card.style.transform = `rotate(${state.rotation}deg) translate(${state.currentX}px, ${state.currentY}px)`
      })

      if (stillMoving) {
        requestAnimationFrame(tick)
      } else {
        animating = false
      }
    }

    function startLerp() {
      if (!animating) {
        animating = true
        requestAnimationFrame(tick)
      }
    }

    container.addEventListener('mousemove', (e) => {
      const rect = container.getBoundingClientRect()
      targetDx = (e.clientX - rect.left - rect.width / 2) / (rect.width / 2)
      targetDy = (e.clientY - rect.top - rect.height / 2) / (rect.height / 2)
      startLerp()
    })

    container.addEventListener('touchmove', (e) => {
      const touch = e.touches[0]
      const rect = container.getBoundingClientRect()
      targetDx = (touch.clientX - rect.left - rect.width / 2) / (rect.width / 2)
      targetDy = (touch.clientY - rect.top - rect.height / 2) / (rect.height / 2)
      startLerp()
    }, { passive: true })

    container.addEventListener('mouseleave', () => {
      targetDx = 0
      targetDy = 0
      startLerp()
    })
  }

  // Run on initial load
  initParallax()

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', initParallax)
</script>
